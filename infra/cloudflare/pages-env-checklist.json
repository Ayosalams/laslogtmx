{
  "version": "2026-07-01",
  "note": "Set in Cloudflare Dashboard → Pages → [project] → Settings → Environment variables. Never commit real values.",
  "projects": {
    "laslogtmx-app": {
      "domain": "app.laslogtmx.com",
      "branch": "main",
      "environment": "Production",
      "required": [
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "NEXT_PUBLIC_APP_URL=https://laslogtmx.com",
        "NEXT_PUBLIC_WEB_APP_URL=https://app.laslogtmx.com",
        "NEXT_PUBLIC_DEV_URL=https://dev.laslogtmx.com",
        "NEXT_PUBLIC_MARKETING_URL=https://laslogtmx.com"
      ],
      "server_runtime": [
        "SUPABASE_SERVICE_ROLE_KEY",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "VAPID_PRIVATE_KEY",
        "PUSH_WEBHOOK_SECRET",
        "LOAD_MATCH_WEBHOOK_SECRET"
      ],
      "recommended": [
        "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_SENTRY_DSN",
        "SENTRY_DSN"
      ]
    },
    "laslogtmx-marketing": {
      "domain": "laslogtmx.com",
      "branch": "main",
      "environment": "Production",
      "required": [
        "NEXT_PUBLIC_MARKETING_URL=https://laslogtmx.com",
        "NEXT_PUBLIC_WEB_APP_URL=https://app.laslogtmx.com"
      ],
      "server_runtime": [],
      "note": "Mostly static export — minimal env vars"
    },
    "laslogtmx-dev": {
      "domain": "dev.laslogtmx.com",
      "branch": "develop",
      "environment": "Production",
      "template": "infra/staging/laslogtmx-dev.env.example",
      "required": [
        "NEXT_PUBLIC_APP_URL=https://dev.laslogtmx.com",
        "NEXT_PUBLIC_WEB_APP_URL=https://dev.laslogtmx.com",
        "NEXT_PUBLIC_DEV_URL=https://dev.laslogtmx.com",
        "NEXT_PUBLIC_MARKETING_URL=https://dev.laslogtmx.com",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY"
      ],
      "server_runtime": [
        "SUPABASE_SERVICE_ROLE_KEY",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET"
      ],
      "note": "Use SEPARATE staging Supabase project + Stripe TEST keys only"
    }
  },
  "supabase_auth_redirect_urls": {
    "production_project": [
      "https://app.laslogtmx.com/**",
      "https://laslogtmx.com/**",
      "http://localhost:3000/**"
    ],
    "staging_project": [
      "https://dev.laslogtmx.com/**",
      "http://localhost:3000/**"
    ],
    "dashboard_path": "Supabase → Authentication → URL Configuration"
  }
}