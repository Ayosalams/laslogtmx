# =============================================================================
# laslogtmx-dev — Cloudflare Pages Staging Environment Variables
# Project: laslogtmx-dev | Branch: develop | Domain: dev.laslogtmx.com
# Root directory: / (monorepo root — build:web lives in root package.json)
#
# Copy values into Cloudflare Dashboard → laslogtmx-dev → Settings →
# Environment variables → Preview (or branch-specific for develop).
# NEVER commit real keys. Use a separate Supabase STAGING project.
# =============================================================================

# ── Staging URLs (override production defaults) ──
NEXT_PUBLIC_APP_URL=https://dev.laslogtmx.com
NEXT_PUBLIC_WEB_APP_URL=https://dev.laslogtmx.com
NEXT_PUBLIC_DEV_URL=https://dev.laslogtmx.com
NEXT_PUBLIC_MARKETING_URL=https://dev.laslogtmx.com

# ── Staging Supabase (separate project from production) ──
# Create a dedicated Supabase project for staging (e.g. laslogtmx-staging).
# Run migrations + supabase/seed.staging.sql on that project only.
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-staging-anon-or-publishable-key-here
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key-here

# ── Stripe Test Mode (staging only — pk_test_ / sk_test_ prefixes) ──
# Dashboard → Developers → API keys → Test mode
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-test-publishable-key
STRIPE_SECRET_KEY=sk_test_your-stripe-test-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-test-webhook-secret

# ── Make.com Webhooks (optional staging scenarios) ──
MAKE_COM_QUICKBOOKS_WEBHOOK=
MAKE_COM_DAT_WEBHOOK=
MAKE_COM_FRAUD_WEBHOOK=

# ── Web Push (generate separate VAPID keys for staging) ──
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
PUSH_WEBHOOK_SECRET=

# ── External load match webhook ──
LOAD_MATCH_WEBHOOK_SECRET=

# ── Monitoring (optional — separate Sentry project for staging) ──
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# ── Rate limiting (optional — separate Upstash DB for staging) ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=