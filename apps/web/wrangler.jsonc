{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "laslogtmx-web", // Neutral name — works for both prod + dev
  "main": "./src/index.ts",
  "compatibility_date": "2026-06-27",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./dist/client", // Adjust if your OpenNext output differs
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*",
      "/auth/*",
      "/loads/*",
      "/expenses/*"
    ]
  },
  "preview_urls": true,
  "observability": {
    "enabled": true
  }
}