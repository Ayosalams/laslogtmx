        "run_worker_first": ["/api/*", "/auth/*", "/loads/*", "/expenses/*"]
      },
      "env": {
        "production": { "cf_project": "laslogtmx-app", "domain": "app.laslogtmx.com" },
        "preview": { "cf_project": "laslogtmx-dev", "domain": "dev.laslogtmx.com" }
      }
    }
  },
  "develop_branch": {
