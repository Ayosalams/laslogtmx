{
  "checkpoint": "cloudflare-pages-multi-project",
  "version": "2026-06-24",
  "status": "complete",
  "backup_branch": "backup-before-cf-build-supabase-fix",
  "structure": {
    "marketing": {
      "path": "apps/marketing",
      "purpose": "laslogtmx.com - marketing / landing site",
      "framework": "Next.js (static export for CF Pages)",
      "production_branch": "main",
      "cf_pages_project": "laslogtmx-marketing",
      "root_directory_in_cf": "apps/marketing",
      "build_command": "npm run build:marketing",
      "build_script": "next build",
      "build_note": "build:marketing exists in apps/marketing/package.json; root turbo script optional",
      "build_output": "out",
      "wrangler_config": "apps/marketing/wrangler.jsonc"
    },
    "web": {
      "path": "apps/web",
      "purpose": "app.laslogtmx.com - full TMS web app",
      "framework": "Next.js (OpenNext Cloudflare adapter)",
      "production_branch": "main",
      "cf_pages_project": "laslogtmx-app",
      "root_directory_in_cf": "apps/web",
      "root_directory_alt": "/",
      "root_directory_note": "apps/web root: use npm run build or npm run build:web (both defined locally). Monorepo root / also works with npm run build:web.",
      "build_command": "npm run build",
      "build_command_alt": "npm run build:web",
      "install_command_apps_web": "cd ../.. && npm ci",
      "build_script": "opennextjs-cloudflare build",
      "build_delegate_script": "npm run build:web",
      "build_output": "apps/web/.open-next/assets",
      "build_output_wrangler_relative": ".open-next/assets",
      "worker_entry": "apps/web/.open-next/worker.js",
      "worker_entry_wrangler_relative": ".open-next/worker.js",
      "wrangler_config": "apps/web/wrangler.jsonc",
      "nodejs_version": "20",
      "build_watch_paths": {
        "include": ["apps/web/**", "packages/**", "features/**"],
        "exclude": ["apps/marketing/**", "apps/mobile/**"]
      }
    }
  },
  "apps_web_scripts": {
    "build": "npm run build:web",
    "dev": "npm run dev:web --prefix ../..",
    "build:web": "opennextjs-cloudflare build",
    "dev:web": "next dev"
  },
  "root_scripts": {
    "build:web": "turbo run build:web --filter=web",
    "dev:web": "turbo run dev:web --filter=web",
    "build:marketing": "turbo run build:marketing --filter=marketing",
    "dev:marketing": "turbo run dev:marketing --filter=marketing"
  },
  "turbo": {
    "build_task": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "out/**", "dist/**", ".open-next/**"]
    },
    "build_web_task": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", ".open-next/**"]
    },
    "dev_web_task": {
      "cache": false,
      "persistent": true
    }
  },
  "wrangler": {
    "format": "jsonc",
    "marketing": {
      "name": "laslogtmx-marketing",
      "compatibility_date": "2026-06-21",
      "pages_build_output_dir": "./out",
      "assets_directory": "./out",
      "main": null
    },
    "web": {
      "name": "laslogtmx-app",
      "compatibility_date": "2026-06-24",
      "compatibility_flags": ["nodejs_compat"],
      "pages_build_output_dir": ".open-next/assets",
      "assets_directory": ".open-next/assets",
      "main": ".open-next/worker.js"
    },
    "replaced": ["apps/marketing/wrangler.toml", "apps/web/wrangler.toml"]
  },
  "domains": {
    "marketing": "laslogtmx.com",
    "app": "app.laslogtmx.com",
    "staging": "dev.laslogtmx.com",
    "staging_branch": "develop"
  },
  "deployment": {
    "production": {
      "branch": "main",
      "marketing_project_root": "apps/marketing",
      "web_project_root": "apps/web",
      "web_project_root_alt": "/",
      "use_wrangler_config_as_source_of_truth": true,
      "wrangler_config_path": "apps/web/wrangler.jsonc"
    },
    "staging": {
      "branch": "develop",
      "note": "Configure preview or separate staging project in CF Pages. Set NEXT_PUBLIC_*_URL overrides on the branch for both marketing and web. Add domains to Supabase auth allowlist."
    }
  },
  "files": {
    "root_configs": ["package.json", "turbo.json"],
    "marketing_configs": [
      "package.json",
      "next.config.js",
      "wrangler.jsonc",
      "tsconfig.json",
      "app/layout.tsx",
      "app/page.tsx",
      "app/globals.css"
    ],
    "web_configs": [
      "package.json",
      "open-next.config.ts",
      "wrangler.jsonc"
    ],
    "gitignore_added": [".open-next/", ".vercel/"],
    "checkpoint": ".agents/checkpoints/cloudflare-pages-structure.json"
  },
  "cf_pages_laslogtmx_app": {
    "project": "laslogtmx-app",
    "production_branch": "main",
    "nodejs_version": "20",
    "framework_preset": "None",
    "recommended": "option_a_apps_web_root",
    "option_a_apps_web_root": {
      "root_directory": "apps/web",
      "build_command": "npm run build:web",
      "build_command_alt": "npm run build",
      "build_output_directory": ".open-next/assets",
      "install_command": "cd ../.. && npm ci"
    },
    "option_b_monorepo_root": {
      "root_directory": "/",
      "build_command": "npm run build:web",
      "build_output_directory": "apps/web/.open-next/assets",
      "install_command": "npm ci"
    },
    "environment_variables": {
      "required_at_build_time": [
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY"
      ],
      "recommended": [
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_WEB_APP_URL",
        "NEXT_PUBLIC_SENTRY_DSN"
      ],
      "server_runtime_only": [
        "SUPABASE_SERVICE_ROLE_KEY",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "VAPID_PRIVATE_KEY",
        "PUSH_WEBHOOK_SECRET"
      ],
      "note": "Build succeeds without Supabase vars (SSG placeholders in lib/supabase.ts) but auth will not work until real NEXT_PUBLIC_* values are set in CF Pages env and redeployed."
    }
  },
  "supabase_build": {
    "file": "lib/supabase.ts",
    "ssg_tolerant": true,
    "placeholder_detection": true,
    "auth_disabled_during_build": true,
    "build_warning": "[supabase] Build proceeding without real Supabase config (SSG-safe placeholders)."
  },
  "next_steps": [
    "Apply laslogtmx-app CF Pages settings (option_a recommended — see cf_pages_laslogtmx_app)",
    "Set NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY in CF Pages env, then redeploy",
    "Point custom domain app.laslogtmx.com to laslogtmx-app",
    "Configure develop branch for dev.laslogtmx.com"
  ],
  "verification": {
    "wrangler_jsonc_created": true,
    "wrangler_toml_removed": true,
    "gitignore_updated": true,
    "backup_branch": "backup-before-cf-build-supabase-fix",
    "build_web_script_root": true,
    "build_web_script_apps_web": true,
    "dev_web_script_root": true,
    "dev_web_script_apps_web": true,
    "build_delegate_no_recursion": true,
    "build_web_local_pass": true,
    "build_web_local_pass_placeholder_env": true,
    "build_web_local_date": "2026-06-24",
    "supabase_ssg_tolerant": true,
    "supabase_build_warning": true,
    "build_web_adapter": "opennextjs-cloudflare",
    "build_web_output_dir": "apps/web/.open-next",
    "turbo_open_next_outputs": true,
    "build_marketing_script_added": true,
    "build_marketing_local_pass": true,
    "build_marketing_output_dir": "apps/marketing/out"
  }
}