{
  "checkpoint": "cloudflare-pages-multi-project",
  "version": "2026-06-24",
  "status": "complete",
  "backup_branch": "backup-before-marketing-build-config",
  "structure": {
    "marketing": {
      "path": "apps/marketing",
      "purpose": "laslogtmx.com - marketing / landing site",
      "framework": "Next.js (static export for CF Pages)",
      "production_branch": "main",
      "cf_pages_project": "laslogtmx-marketing",
      "root_directory_in_cf": "apps/marketing",
      "build_command": "npm run build:marketing",
      "build_script": "next build",
      "build_note": "Next.js 15 removed next export; output: export in next.config.js writes to out/",
      "build_output": "out",
      "wrangler_config": "apps/marketing/wrangler.jsonc"
    },
    "web": {
      "path": "apps/web",
      "purpose": "app.laslogtmx.com - full TMS web app",
      "framework": "Next.js (OpenNext Cloudflare adapter)",
      "production_branch": "main",
      "cf_pages_project": "laslogtmx-web",
      "root_directory_in_cf": "apps/web",
      "build_command": "npm run build:web",
      "build_output": ".open-next/assets",
      "worker_entry": ".open-next/worker.js",
      "wrangler_config": "apps/web/wrangler.jsonc"
    }
  },
  "wrangler": {
    "format": "jsonc",
    "marketing": {
      "name": "laslogtmx-marketing",
      "compatibility_date": "2026-06-21",
      "pages_build_output_dir": "./out",
      "assets_directory": "./out",
      "main": null
    },
    "web": {
      "name": "laslogtmx-web",
      "compatibility_date": "2026-06-21",
      "compatibility_flags": ["nodejs_compat"],
      "pages_build_output_dir": ".open-next/assets",
      "assets_directory": ".open-next/assets",
      "main": ".open-next/worker.js"
    },
    "replaced": ["apps/marketing/wrangler.toml", "apps/web/wrangler.toml"]
  },
  "domains": {
    "marketing": "laslogtmx.com",
    "app": "app.laslogtmx.com",
    "staging": "dev.laslogtmx.com",
    "staging_branch": "develop"
  },
  "deployment": {
    "production": {
      "branch": "main",
      "marketing_project_root": "apps/marketing",
      "web_project_root": "apps/web",
      "use_wrangler_config_as_source_of_truth": true
    },
    "staging": {
      "branch": "develop",
      "note": "Configure preview or separate staging project in CF Pages. Set NEXT_PUBLIC_*_URL overrides on the branch for both marketing and web. Add domains to Supabase auth allowlist."
    }
  },
  "files": {
    "marketing_configs": [
      "package.json",
      "next.config.js",
      "wrangler.jsonc",
      "tsconfig.json",
      "app/layout.tsx",
      "app/page.tsx",
      "app/globals.css"
    ],
    "web_configs": [
      "wrangler.jsonc"
    ],
    "gitignore_added": [".open-next/", ".vercel/"],
    "checkpoint": ".agents/checkpoints/cloudflare-pages-structure.json"
  },
  "next_steps": [
    "Install @opennextjs/cloudflare in apps/web and wire build:web to opennextjs-cloudflare build",
    "Create laslogtmx-marketing and laslogtmx-web CF Pages projects via dashboard",
    "Enable V2 build system and opt-in to Wrangler configuration file as source of truth",
    "Point custom domains laslogtmx.com and app.laslogtmx.com",
    "Configure develop branch for dev.laslogtmx.com",
    "Set env vars via CF dashboard (never commit real keys)"
  ],
  "verification": {
    "wrangler_jsonc_created": true,
    "wrangler_toml_removed": true,
    "gitignore_updated": true,
    "backup_branch": "backup-before-marketing-build-config",
    "build_marketing_script_added": true,
    "build_marketing_local_pass": true,
    "build_output_dir": "apps/marketing/out"
  }
}