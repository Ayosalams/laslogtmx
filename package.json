{
  "name": "laslogtmx",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "turbo run dev --filter=web",
    "dev:mobile": "turbo run start --filter=mobile",
    "dev:marketing": "turbo run dev:marketing --filter=marketing",
    "build:web": "turbo run build --filter=web",
    "build:mobile": "turbo run build --filter=mobile",
    "build:marketing": "turbo run build:marketing --filter=marketing",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "overrides": {
    "xmldom": "^0.8.13",
    "tar": "^7.4.0",
    "uuid": "^11.1.1",
    "postcss": "^8.5.10",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}