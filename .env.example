# =============================================================================
# laslogTMX Environment Variables
# Copy to .env.local and fill in manually. NEVER commit real keys.
#
# PRODUCTION  → main branch → laslogtmx-app / laslogtmx-marketing CF projects
# STAGING     → develop branch → laslogtmx-dev CF project (dev.laslogtmx.com)
#               See infra/staging/laslogtmx-dev.env.example for full staging list
# =============================================================================

# ── PRODUCTION: Domain URLs (laslogtmx.com migration complete) ──
# Set these in Cloudflare Pages → laslogtmx-app / laslogtmx-marketing → Production env
NEXT_PUBLIC_APP_URL=https://laslogtmx.com
NEXT_PUBLIC_WEB_APP_URL=https://app.laslogtmx.com
NEXT_PUBLIC_DEV_URL=https://dev.laslogtmx.com
NEXT_PUBLIC_MARKETING_URL=https://laslogtmx.com

# ── STAGING: Domain URL overrides (develop branch / laslogtmx-dev project) ──
# Set these in Cloudflare Pages → laslogtmx-dev → Production env (develop is prod branch)
# NEXT_PUBLIC_APP_URL=https://dev.laslogtmx.com
# NEXT_PUBLIC_WEB_APP_URL=https://dev.laslogtmx.com
# NEXT_PUBLIC_MARKETING_URL=https://dev.laslogtmx.com

# ── PRODUCTION: Supabase (main Supabase project) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-production-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-or-publishable-key-here
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key-here

# ── STAGING: Supabase (separate staging project — NOT production) ──
# Use a dedicated Supabase project. Run supabase/seed.staging.sql after migrations.
# NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-staging-anon-or-publishable-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key-here

# ── PRODUCTION: Stripe (live mode — pk_live_ / sk_live_ prefixes) ──
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-live-publishable-key
STRIPE_SECRET_KEY=sk_live_your-stripe-live-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-live-webhook-secret

# ── STAGING: Stripe (test mode only — pk_test_ / sk_test_ prefixes) ──
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-test-publishable-key
# STRIPE_SECRET_KEY=sk_test_your-stripe-test-secret-key
# STRIPE_WEBHOOK_SECRET=whsec_your-stripe-test-webhook-secret

# Make.com Webhooks (for Phase 1 integrations)
MAKE_COM_QUICKBOOKS_WEBHOOK=
MAKE_COM_DAT_WEBHOOK=
MAKE_COM_FRAUD_WEBHOOK=

# Web Push (VAPID keys — generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Push dispatch webhook (Supabase DB webhook → POST /api/push/send)
PUSH_WEBHOOK_SECRET=

# External load match webhook (Make.com → POST /api/load-match/external)
LOAD_MATCH_WEBHOOK_SECRET=

# ── MCP Server tokens (Windows User Environment Variables — NOT .env.local) ──
# Set these in Windows Settings > Environment Variables (User scope).
# Run: .\infra\mcp\apply-mcp-config.ps1  then  .\infra\mcp\verify-mcp.ps1
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your-github-pat-here
# SUPABASE_PROJECT_REF=your-project-ref-here
# SUPABASE_ACCESS_TOKEN=sbp_your-supabase-pat-here

# ── Production Readiness: Monitoring & Hardening (one-man shop) ──
# Sentry Error Monitoring (web + mobile client tracking)
# Get DSN from sentry.io → Project → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Upstash Redis for App-level Rate Limiting (Load Board posting/bidding)
# Free tier at console.upstash.com — use REST API creds
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: Supabase table for unified app logs (errors + actions). Create via dashboard or migration if desired.

# ── AI Chat (OKF Router + RAG) ──
# File-based RAG works without any key. Set below for optional LLM synthesis via OpenRouter-compatible API.
# AI_CHAT_API_KEY=
# AI_CHAT_BASE_URL=https://openrouter.ai/api/v1
# AI_CHAT_MODEL=openrouter/auto
# OPENROUTER_API_KEY=          # alias for AI_CHAT_API_KEY
# OPENROUTER_SITE_URL=https://app.laslogtmx.com